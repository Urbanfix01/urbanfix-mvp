# Backend web / API base para Expo
# En local puedes usar, por ejemplo:
# EXPO_PUBLIC_PUBLIC_WEB_URL=http://192.168.0.25:3000
EXPO_PUBLIC_PUBLIC_WEB_URL=

# Google Maps / Places (Expo)
# Puedes usar una sola key general o separar por plataforma.

# Recomendado para Android (SDK Maps nativo)
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=

# Recomendado para iOS (si habilitas Google Maps SDK en iOS)
EXPO_PUBLIC_GOOGLE_MAPS_IOS_API_KEY=

# Key general de fallback (web y autocomplete)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Key específica para Places API (autocomplete + details)
EXPO_PUBLIC_PLACES_API_KEY=

# Web Places JS (si quieres separar la key web)
EXPO_PUBLIC_WEB_API_KEY=
